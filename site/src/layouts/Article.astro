---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  maturity?: 'seed' | 'budding' | 'evergreen';
  tags?: string[];
  date?: Date;
}
const { title, description, maturity = 'seed', tags = [], date } = Astro.props;
const dateStr = date ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
---
<Base title={title} description={description}>
  <article class="prose">
    <header style="margin-bottom: 1.5rem;">
      <div class="maturity {maturity}">{maturity}</div>
      <h1 style="margin-top: 0.5rem;">{title}</h1>
      {description && <p class="section-intro" style="margin-top: 0; font-size: 1.05rem;">{description}</p>}
      {tags.length > 0 && (
        <div class="tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
      )}
      {dateStr && <p style="font-size: 0.8rem; color: var(--color-muted); margin: 0;">{dateStr}</p>}
    </header>
    <slot />
  </article>
</Base>
