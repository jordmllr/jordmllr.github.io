---
import Base from '../../layouts/Base.astro';
---
<Base title="Efficient Structures">
  <h1 style="margin-top: 0;">Efficient Structures</h1>
  <p class="section-intro">
    Structural systems that do more with less — shells, gridshells, space trusses,
    and cellular solids — investigated with an eye to buildable domestic scale.
  </p>

  <nav style="margin-top: 2.5rem;">
    <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.25rem;">

      <li>
        <a href="/structures/shells/index" style="font-weight: 600;">Shells</a>
        <span style="color: var(--color-muted); font-size: 0.85rem; margin-left: 0.5rem;">
          Thin shells and gridshells — structural logic of doubly-curved surfaces
        </span>
        <ul style="list-style: none; padding-left: 1.5rem; margin-top: 0.25rem; display: flex; flex-direction: column; gap: 0.2rem;">
          <li>
            <a href="/structures/shells/grid-shells/gridshell-types">Gridshell Types: A Survey</a>
            <span style="color: var(--color-muted); font-size: 0.8rem; margin-left: 0.5rem;">taxonomy of gridding methods</span>
            <span class="maturity seed" style="margin-left: 0.5rem; font-size: 0.7rem;">seed</span>
          </li>
        </ul>
      </li>

      <li style="margin-top: 0.75rem;">
        <a href="/structures/cellular-structures" style="font-weight: 600;">Cellular Structures</a>
        <span style="color: var(--color-muted); font-size: 0.85rem; margin-left: 0.5rem;">
          Foams, lattices, and cellular solids
        </span>
        <span class="maturity seed" style="margin-left: 0.5rem; font-size: 0.7rem;">seed</span>
      </li>

    </ul>
  </nav>
</Base>
