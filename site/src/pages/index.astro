---
import Base from '../layouts/Base.astro';
---
<Base title="Lum">
  <section>
    <h1 style="margin-top: 0;">Lum</h1>
    <p class="section-intro">
      An open engineering notebook on material-efficient structures, locally sourced
      materials, and buildable design — from gridshells to sheds, from Anchorage timber
      to pressed kelp.
    </p>
  </section>

  <section style="margin-top: 3rem;">
    <div class="card-grid">
      <a class="card" href="/structures">
        <span class="card-title">Efficient Structures</span>
        <span class="card-desc">Shells, gridshells, space trusses, and cellular solids — structural logic with an eye to domestic-scale construction.</span>
      </a>
      <div class="card" style="opacity: 0.5; cursor: default;">
        <span class="card-title">Materials</span>
        <span class="card-desc">Local material research and physical tests — timber, bio-adhesives, algae composites. <em>Coming soon.</em></span>
      </div>
      <div class="card" style="opacity: 0.5; cursor: default;">
        <span class="card-title">Designs</span>
        <span class="card-desc">Design explorations — furniture, sheds, greenhouses, ADUs, art. <em>Coming soon.</em></span>
      </div>
    </div>
  </section>
</Base>
